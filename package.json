{
  "name": "tagger",
  "version": "0.1.0",
  "description": "Servicio categorización gastos. Cascada regex→Bancard→comercio→MCC→IA(Gemma).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:consistency": "node scripts/check-consistency.mjs",
    "tasks:sync": "node scripts/sync-tasks.mjs",
    "tasks:next": "node scripts/next-task.mjs",
    "tasks:start": "node scripts/start-task.mjs",
    "tasks:check": "node scripts/check-task.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:load": "tsx scripts/load.ts",
    "db:load:all": "tsx scripts/load.ts all",
    "db:load:categorias": "tsx scripts/load.ts categorias",
    "db:load:reglas": "tsx scripts/load.ts reglas",
    "db:load:mcc": "tsx scripts/load.ts mcc",
    "db:load:mcc-general": "tsx scripts/load.ts mcc-general",
    "db:load:mcc-categoria": "tsx scripts/load.ts mcc-categoria",
    "db:load:mcc-extras": "tsx scripts/load.ts mcc-extras",
    "db:load:mango-p2p": "tsx scripts/load.ts mango-p2p",
    "db:load:comercios": "tsx scripts/load.ts comercios",
    "db:load:comercios-bancard": "tsx scripts/load.ts comercios-bancard",
    "db:load:comercios-bancard-masivo": "tsx scripts/load.ts comercios-bancard-masivo",
    "db:seed:all": "tsx scripts/load.ts all",
    "test:masivo": "tsx scripts/test-masivo.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "csv-parse": "^6.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
