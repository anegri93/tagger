TAGGER_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://tagger:tagger@localhost:5432/tagger

# IA fallback (capa 4 del pipeline) + /chat — ambos vía OpenRouter.
# Si IA_ENABLED=true y no hay key, el fallback queda no-op (movs sin cat).
IA_ENABLED=true
OPENROUTER_API_KEY=
# Modelo preferido. Si vacío usa el primero del fallback chain hardcoded
# (openai/gpt-oss-120b:free → meta-llama → hermes → qwen).
OPENROUTER_IA_MODEL=
IA_MAX_CONCURRENT=4

# Postgres pool: máx conexiones simultáneas (default 30)
DB_POOL_MAX=30
# LRU cache de reglas por scope: máx scopes en memoria (default 5000)
REGLAS_CACHE_MAX=5000
# TTL de cache reglas en ms (default 60000 = 60s)
REGLAS_CACHE_TTL_MS=60000

API_KEY=replace-with-strong-random-key-min-16-chars
CONFIDENCE_THRESHOLD=0.7
LOG_LEVEL=info
SEED_STRATEGY=auto
